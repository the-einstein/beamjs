#!/usr/bin/env node

/**
 * BeamJS CLI launcher
 *
 * This shim finds the bundled BEAM release and exec's it with the
 * original CLI arguments. The actual runtime is Elixir/Erlang on the
 * BEAM VM — no Node.js is used beyond this tiny launcher.
 */

const { execFileSync } = require("child_process");
const path = require("path");
const fs = require("fs");

const isWindows = process.platform === "win32";
const packageDir = path.resolve(__dirname, "..");
const releaseDir = path.join(packageDir, "release");
const releaseBin = path.join(releaseDir, "bin", isWindows ? "beamjs.bat" : "beamjs");

if (!fs.existsSync(releaseBin)) {
  console.error("Error: BeamJS release binary not found.");
  console.error("Try reinstalling: npm install -g beamjs-runtime");
  process.exit(1);
}

// Pass all CLI args to the release binary via BEAMJS_ARGS
const args = process.argv.slice(2);
const beamjsArgs = args.map(a => a.includes(" ") ? `"${a}"` : a).join(" ");

const env = {
  ...process.env,
  BEAMJS_ARGS: beamjsArgs,
  RELEASE_DISTRIBUTION: "none",
};

try {
  if (isWindows) {
    // On Windows, use cmd /c to run .bat files
    execFileSync("cmd", ["/c", releaseBin, "eval", "BeamjsCli.Release.cli()"], {
      stdio: "inherit",
      env,
    });
  } else {
    execFileSync(releaseBin, ["eval", "BeamjsCli.Release.cli()"], {
      stdio: "inherit",
      env,
    });
  }
} catch (e) {
  process.exit(e.status || 1);
}
